# Vercel'de Settings -> Environment Variables bolumunden girin. Koda yazmayin!

# Helius RPC adresiniz (zorunlu degil ama siddetle onerilir; bos birakilirsa
# yavas/limitli public RPC'ye duser)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=HELIUS_ANAHTARINIZ

# xPoints API taban adresi (bos birakilirsa varsayilan kullanilir)
POINTS_API_BASE=https://points-api.xstocks.fi/api/v1

# Varsa leaderboard JSON adresi (Network sekmesinden bulduysaniz). Bos birakin -> modul gizlenir.
LEADERBOARD_URL=
